{
    "functions": {
        "api/whatsapp.js": {
            "maxDuration": 30
        },
        "api/portal-render.js": {
            "includeFiles": "dist/index.html"
        }
    },
    "rewrites": [
        {
            "source": "/portal",
            "destination": "/api/portal-render"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ],
    "crons": [
        {
            "path": "/api/cron",
            "schedule": "0 12 * * *"
        }
    ]
}