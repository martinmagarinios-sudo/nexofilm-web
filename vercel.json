{
    "functions": {
        "api/whatsapp.js": {
            "maxDuration": 30
        }
    },
    "redirects": [
        {
            "source": "/portfolio",
            "destination": "/#portfolio",
            "permanent": false
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ],
    "crons": [
        {
            "path": "/api/cron",
            "schedule": "0 12 * * *"
        }
    ]
}